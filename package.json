{
  "name": "discord-command-controls",
  "version": "0.1.5",
  "description": "Zemiax TypeScript helpers for Discord command catalogs, toggles, and dashboard policies.",
  "type": "module",
  "license": "MIT",
  "author": "Vaguul (Zemiax)",
  "sideEffects": false,
  "files": [
    "docs",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vaguul/discord-command-controls.git"
  },
  "keywords": [
    "discord",
    "discordjs",
    "command-controls",
    "permissions",
    "moderation",
    "dashboard"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "docs:catalog": "tsx scripts/generate-command-catalog-doc.ts",
    "validate": "npm run typecheck && npm test",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "npm run build",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
